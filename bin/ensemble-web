#!/usr/bin/env python3
"""maestro web — interactive browser dashboard over `ensemble`. Stdlib only.

Launched by `ensemble web`, which sets ENSEMBLE_BIN to the ensemble CLI path.

Security: every /api/* call requires the session token printed at startup
(?t=… or X-Token header). Binds 127.0.0.1 by default; pass --lan to bind
0.0.0.0 for a browser on another host (WSL → Windows) — the token still
gates all data and actions. Read endpoints: /api/state, /api/log. Write
endpoints (token + confirmed in the UI): /api/stop, /api/reap.
"""
import http.server, json, os, re, secrets, socket, subprocess, sys
from urllib.parse import urlparse, parse_qs

ENSEMBLE = os.environ.get("ENSEMBLE_BIN", "ensemble")
TOKEN = os.environ.get("ENSEMBLE_WEB_TOKEN") or secrets.token_urlsafe(18)

_ANSI = re.compile(r"\x1b\[[0-9;?]*[ -/]*[@-~]|\x1b\][^\x07\x1b]*(?:\x07|\x1b\\)|\x1b[@-_]")
_CTRL = re.compile(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]")


def _clean(s):
    s = s.rstrip("\n").rstrip("\r")
    if "\r" in s:
        s = s.split("\r")[-1]
    return _CTRL.sub("", _ANSI.sub("", s).replace("\t", "    ")).rstrip()


def _run(args, timeout=12):
    try:
        return subprocess.run([ENSEMBLE, *args], capture_output=True, text=True, timeout=timeout).stdout
    except Exception:
        return ""


def get_jobs():
    jobs = []
    for line in _run(["jobs", "--porcelain"]).splitlines():
        p = line.split("\t")
        if len(p) >= 5:
            jobs.append(dict(kind=p[0], name=p[1], status=p[2], age=int(p[3] or 0), log=p[4]))
    return jobs


def get_state():
    sysd, agents = {}, []
    for line in _run(["ps", "--stints", "--porcelain"]).splitlines():
        p = line.split("\t")
        if p[0] == "SYS" and len(p) >= 6:
            sysd = dict(rampct=float(p[1] or 0), used=p[2], total=p[3],
                        swappct=float(p[4] or 0), load=p[5])
        elif p[0] == "T" and len(p) >= 7:
            agents.append(dict(pct=float(p[1] or 0), rss=int(p[2] or 0), cpu=float(p[3] or 0),
                               nprocs=p[4], kind=p[5], proj=p[6]))
    reap = []
    for line in _run(["reap", "--porcelain"]).splitlines():
        p = line.split("\t")
        if len(p) >= 4:
            reap.append(dict(pids=p[0], mb=int(p[1] or 0), kind=p[2], label=p[3].strip()))
    return dict(sys=sysd, agents=agents, jobs=get_jobs(), reap=reap)


def get_log(name, n=240):
    for j in get_jobs():
        if j["name"] == name:
            try:
                with open(j["log"], "r", errors="replace", newline="\n") as f:
                    return [_clean(x) for x in f.readlines()[-n:]]
            except Exception:
                return ["(no output yet)"]
    return ["(unknown run)"]


# --- kanban boards: a registry of per-project board-state.json files ----------
REG = os.path.expanduser("~/.ensemble/web/boards")
BOARDS = []   # resolved board-state.json paths; set in main()


def resolve_board(arg):
    """A --board arg may be a project dir, its orchestration/, or the json itself."""
    p = os.path.expanduser(arg)
    for c in (p, os.path.join(p, "orchestration", "board-state.json"), os.path.join(p, "board-state.json")):
        if os.path.isfile(c):
            return os.path.abspath(c)
    return None


def register_boards(args):
    """Load the persisted registry, add any --board args, persist, return live paths."""
    paths = []
    if os.path.isfile(REG):
        paths = [l.strip() for l in open(REG) if l.strip() and not l.startswith("#")]
    for a in args:
        jp = resolve_board(a)
        if jp and jp not in paths:
            paths.append(jp)
    try:
        os.makedirs(os.path.dirname(REG), exist_ok=True)
        with open(REG, "w") as f:
            f.write("\n".join(paths) + ("\n" if paths else ""))
    except Exception:
        pass
    return [p for p in paths if os.path.isfile(p)]


def boards_list():
    out = []
    for i, p in enumerate(BOARDS):
        name = os.path.basename(os.path.dirname(os.path.dirname(p))) or "board"
        try:
            name = json.load(open(p)).get("project") or name
        except Exception:
            pass
        out.append(dict(id=i, name=name))
    return out


def board_data(i):
    try:
        return json.load(open(BOARDS[i]))
    except Exception:
        return {"error": "unreadable board"}


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, *a):           # quiet
        pass

    def _ok_token(self):
        q = parse_qs(urlparse(self.path).query)
        tok = (q.get("t", [None])[0]) or self.headers.get("X-Token")
        return secrets.compare_digest(str(tok or ""), TOKEN)

    def _send(self, obj, code=200, ctype="application/json"):
        body = obj if isinstance(obj, bytes) else json.dumps(obj).encode()
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        path = urlparse(self.path).path
        if path == "/":
            return self._send(PAGE.encode(), ctype="text/html; charset=utf-8")
        if not self._ok_token():
            return self._send({"error": "forbidden"}, 403)
        if path == "/api/state":
            return self._send(get_state())
        if path == "/api/log":
            name = parse_qs(urlparse(self.path).query).get("name", [""])[0]
            return self._send({"lines": get_log(name)})
        if path == "/api/boards":
            return self._send(boards_list())
        if path == "/api/board":
            try:
                i = int(parse_qs(urlparse(self.path).query).get("id", ["-1"])[0])
            except ValueError:
                i = -1
            if 0 <= i < len(BOARDS):
                return self._send(board_data(i))
            return self._send({"error": "no such board"}, 404)
        self._send({"error": "not found"}, 404)

    def do_POST(self):
        if not self._ok_token():
            return self._send({"error": "forbidden"}, 403)
        path = urlparse(self.path).path
        try:
            n = int(self.headers.get("Content-Length") or 0)
            body = json.loads(self.rfile.read(n) or b"{}")
        except Exception:
            return self._send({"error": "bad body"}, 400)
        if path == "/api/stop":
            name = str(body.get("name", "")).strip()
            if not name:
                return self._send({"error": "name required"}, 400)
            _run(["stop", "--yes", name], timeout=30)
            return self._send({"ok": True})
        if path == "/api/reap":
            pids = str(body.get("pids", "")).replace(",", " ").strip()
            if not pids or not re.fullmatch(r"[0-9 ]+", pids):
                return self._send({"error": "bad pids"}, 400)
            _run(["reap", "--close-pids", pids, "--yes"], timeout=40)
            return self._send({"ok": True})
        self._send({"error": "not found"}, 404)


def main():
    global BOARDS
    port, bind, lan = 8770, "127.0.0.1", False
    board_args = []
    it = iter(sys.argv[1:])
    for a in it:
        if a in ("--lan", "-l"):
            lan, bind = True, "0.0.0.0"
        elif a == "--board":
            try:
                board_args.append(next(it))
            except StopIteration:
                pass
        elif a.isdigit():
            port = int(a)
    BOARDS = register_boards(board_args)
    host = "127.0.0.1"
    if lan:
        try:
            host = subprocess.run(["hostname", "-I"], capture_output=True, text=True).stdout.split()[0]
        except Exception:
            host = socket.gethostname()
    try:
        srv = http.server.ThreadingHTTPServer((bind, port), Handler)
    except OSError as e:
        print(f"[ensemble web] can't bind {bind}:{port} — {e} (try another port: ensemble web 8780)", file=sys.stderr)
        sys.exit(1)
    url = f"http://{host}:{port}/?t={TOKEN}"
    print(f"[ensemble web] open  {url}")
    if BOARDS:
        print(f"[ensemble web] {len(BOARDS)} board tab(s): " + ", ".join(b["name"] for b in boards_list()))
    else:
        print("[ensemble web] no kanban boards yet — add one: ensemble web --board <project-dir>")
    if lan:
        print("[ensemble web] bound 0.0.0.0 (LAN-reachable); the token gates all data + actions.")
    else:
        print("[ensemble web] localhost-only. Browser on another host (WSL → Windows)? re-run: ensemble web --lan")
    print("[ensemble web] Ctrl-C to stop.")
    sys.stdout.flush()   # show the URL+token immediately even when piped/redirected
    try:
        srv.serve_forever()
    except KeyboardInterrupt:
        pass


