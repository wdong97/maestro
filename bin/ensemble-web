<script>
const T=new URLSearchParams(location.search).get('t')||'';
const acked=new Set(), open=new Set(), keptPids=new Set();
const NEEDS=1800, FAILW=14400;
const $=id=>document.getElementById(id);
function toast(m,err){const t=$('toast');t.textContent=m;t.className='toast show'+(err?' err':'');
  clearTimeout(toast._t);toast._t=setTimeout(()=>t.className='toast',2200);}
async function api(path,opt){const u=path+(path.includes('?')?'&':'?')+'t='+encodeURIComponent(T);
  const r=await fetch(u,opt);if(r.status===403){toast('forbidden — open the URL with its ?t= token',1);throw 0;}return r;}
function state(j){const s=j.status;if(s.startsWith('running'))return'running';
  if(s.toLowerCase().includes('stopped'))return'stopped';
  const c=(s.match(/-?\d+/g)||[]).map(Number);return(c.length&&c.some(x=>x!==0))?'failed':'done';}
function lane(j){const st=state(j);if(st==='running')return'running';
  if(acked.has(j.name))return'done';return j.age<((st==='failed'||st==='stopped')?FAILW:NEEDS)?'needs':'done';}
const BADGE={running:['●','var(--cyan)'],done:['✓','var(--green)'],failed:['✗','var(--red)'],stopped:['■','var(--amber)']};
function action(j,st){if(st==='done'&&j.kind==='duel')return'synthesize';
  if(st==='done'&&j.kind==='review')return'read review';return{running:'live',done:'done',failed:'failed',stopped:'stopped'}[st];}
function hms(s){s|=0;return s<60?s+'s':s<3600?(s/60|0)+'m':(s/3600|0)+'h'+((s%3600)/60|0)+'m';}
function runEl(j,dim){const st=state(j),[ch,col]=BADGE[st];
  const d=document.createElement('div');d.className='run'+(dim?' dim':'');
  d.innerHTML=`<span class=dot style=color:${col}>${ch}</span><span class=kind>${j.kind}</span>`+
    `<span class=name>${j.name}</span><span class=act>${action(j,st)}</span><span class=age>${hms(j.age)}</span>`;
  const stopBtn=st==='running'?`<button class="btn danger" data-stop="${j.name}">stop</button>`:'';
  const t=document.createElement('span');t.innerHTML=stopBtn;if(stopBtn)d.appendChild(t.firstChild);
  d.onclick=e=>{if(e.target.dataset.stop)return;acked.add(j.name);
    if(open.has(j.name))open.delete(j.name);else open.add(j.name);render(LAST);};
  return d;}
function laneInto(el,title,arr,dim){el.innerHTML='';const h=document.createElement('div');
  h.className='lane';h.innerHTML=`<b>${title}</b> (${arr.length})`;el.appendChild(h);
  if(!arr.length){const e=document.createElement('div');e.className='empty';
    e.textContent=title==='NEEDS YOU'?"nothing fresh — you're caught up":'nothing running';el.appendChild(e);}
  arr.forEach(j=>{el.appendChild(runEl(j,dim));
    if(open.has(j.name)){const o=document.createElement('div');o.className='out';o.textContent='loading…';
      el.appendChild(o);api('/api/log?name='+encodeURIComponent(j.name)).then(r=>r.json())
        .then(d=>{o.textContent=(d.lines||[]).join('\n')||'(no output yet)';o.scrollTop=o.scrollHeight;}).catch(()=>{});}});}
let LAST={jobs:[],sys:{},agents:[],reap:[]};
function render(s){LAST=s;const jobs=s.jobs||[];
  const running=jobs.filter(j=>state(j)==='running');
  const needs=jobs.filter(j=>lane(j)==='needs');
  const done=jobs.filter(j=>lane(j)==='done').slice(0,12);
  laneInto($('needs'),'NEEDS YOU',needs,false);
  laneInto($('running'),'RUNNING',running,false);
  laneInto($('done'),'DONE',done,true);
  const sys=s.sys||{},rp=Math.round(sys.rampct||0);
  $('summary').textContent=`${needs.length+running.length} active · ${(s.agents||[]).length} sessions · cpu ${Math.round((s.agents||[]).reduce((a,b)=>a+b.cpu,0))}% · ram ${rp}%`;
  $('rambar').style.width=rp+'%';$('rambar').style.background=rp>=85?'var(--red)':rp>=60?'var(--amber)':'var(--green)';
  $('rampct').textContent=rp+'%'+(sys.used?`  ${sys.used}/${sys.total}G`:'');
  const reap=s.reap||[];$('reapbtn').textContent=`Close selected (${reap.length})`;
  const rsig=reap.map(c=>c.pids).join('|');           // only rebuild when the candidate set changes…
  if($('reap').dataset.sig!==rsig){$('reap').dataset.sig=rsig;  // …so it never clobbers your checkboxes
    $('reap').innerHTML=reap.length?'':'<div class=empty>nothing idle to reclaim</div>';
    reap.forEach(c=>{const row=document.createElement('div');row.className='rcand';
      row.innerHTML=`<input type=checkbox ${keptPids.has(c.pids)?'':'checked'} data-pids="${c.pids}"><label>${c.label}</label>`+
        `<span class=mut>${c.mb}M</span>`;$('reap').appendChild(row);});}
  $('agents').innerHTML=(s.agents||[]).map(a=>`<span>${a.kind} ${a.proj} · ${a.rss}M · cpu ${Math.round(a.cpu)}%</span>`).join('');}
document.addEventListener('click',async e=>{
  const name=e.target.dataset.stop;
  if(name){e.stopPropagation();if(!confirm('Stop run "'+name+'"?'))return;
    acked.add(name);await api('/api/stop',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name})});
    toast('stopping '+name);refresh();}
  if(e.target.id==='reapbtn'){const pids=[...document.querySelectorAll('#reap input:checked')].map(c=>c.dataset.pids).join(' ').trim();
    if(!pids){toast('nothing selected to close');return;}
    if(!confirm('Close the checked items? (unchecked stay alive)'))return;
