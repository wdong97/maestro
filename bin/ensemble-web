function esc(x){return(x==null?'':(''+x)).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
function kago(iso){if(!iso)return'';const t=new Date(iso).getTime();if(isNaN(t))return'';return hms(Math.max(0,(Date.now()-t)/1000))+' ago';}
const KST=[['todo','To do'],['in-progress','In progress'],['blocked','Blocked'],['in-review','In review'],['done','Done']];
const LBL={todo:'todo','in-progress':'in progress',blocked:'blocked','in-review':'in review',done:'done'};
const PAL=['#3fb0ff','#a371f7','#3fb950','#d29922','#39c5cf','#f778ba','#ff7b72','#8b949e'];
const pcol=id=>PAL[((+id)||0)%PAL.length];
function pctOf(d){const ts=[];(d.slices||[]).forEach(s=>(s.tasks||[]).forEach(t=>ts.push(t)));
  const done=ts.filter(t=>t.status==='done').length;return ts.length?Math.round(done/ts.length*100):0;}
function kanbanHTML(d){const tasks=[];(d.slices||[]).forEach(sl=>(sl.tasks||[]).forEach(t=>tasks.push(Object.assign({sid:sl.id},t))));
  let h='<div class=kboard>';
  KST.forEach(([k,lbl])=>{const cards=tasks.filter(t=>t.status===k);
    h+='<div class=kcol><h4><span class="kdot s-'+k+'"></span>'+lbl+' <em>'+cards.length+'</em></h4>';
    if(!cards.length)h+='<div class=empty style="padding:4px 2px">—</div>';
    cards.forEach(c=>{h+='<div class="kcard'+(k==='blocked'?' blk':'')+(k==='done'?' dn':'')+'"><div class=ktag>'+esc(c.sid)+
      '</div><div class=ktitle>'+esc(c.title)+'</div><div class=kfoot>'+(c.owner?'@'+esc(c.owner):'unassigned')+
      ' · '+esc(kago(c.updated_at))+'</div>'+(c.note&&k==='blocked'?'<div class=knote>'+esc(c.note)+'</div>':'')+'</div>';});
    h+='</div>';});
  return h+'</div>';}
function roadmapHTML(d,c){let b='';(d.slices||[]).forEach(sl=>{const ts=sl.tasks||[],done=ts.filter(t=>t.status==='done').length,p=ts.length?Math.round(done/ts.length*100):0;
  b+='<div class=slice><div class=shead><span class=sid style="color:'+c+'">'+esc(sl.id)+'</span><span class=stitle>'+esc(sl.title)+
     '</span><span class="sbadge b-'+sl.status+'">'+(LBL[sl.status]||sl.status)+'</span></div><div class=sprog><i style="width:'+p+'%"></i></div>';
  ts.forEach(t=>{b+='<div class=task><span class="kdot s-'+t.status+'"></span><span class=ti>'+esc(t.title)+'</span><span class=tid>'+
     esc(t.id)+' · '+(LBL[t.status]||t.status)+'</span>'+(t.owner?'<span class=who>@'+esc(t.owner)+'</span>':'')+'</div>';});
  if(!ts.length)b+='<div class=empty style="padding:3px 2px">no cards yet</div>';
  const gq=(sl.gate&&sl.gate.quality)||[],gp=(sl.gate&&sl.gate.performance)||[];
  if(gq.length||gp.length){b+='<div class=gates>';[['quality',gq],['performance',gp]].forEach(g=>{if(!g[1].length)return;
    const pass=g[1].filter(x=>x.status==='pass').length;b+='<div><div class=glbl>'+g[0]+' gate · '+pass+'/'+g[1].length+'</div>'+
      g[1].map(x=>'<div class=gck><span class="gdot g-'+x.status+'"></span>'+esc(x.check)+'</div>').join('')+'</div>';});b+='</div>';}
  const all=gq.concat(gp);
  if(all.length){if(sl.sign_off)b+='<div class="signoff ok">✓ signed off — @'+esc(sl.sign_off.by)+' · '+esc(kago(sl.sign_off.at))+'</div>';
    else{const g=all.filter(x=>x.status==='pass').length,ready=g===all.length;
      b+='<div class="signoff'+(ready?' ready':'')+'">'+(ready?'gate green — awaiting sign-off':'awaiting gate ('+g+'/'+all.length+') + sign-off')+'</div>';}}
  const led=sl.ledger||{},lk=Object.keys(led).filter(k=>led[k]!=null);
  if(lk.length)b+='<div class=ledger>'+lk.map(k=>'<span class=lv>'+esc(k)+' <b>'+esc(led[k])+'</b></span>').join('')+'</div>';
  b+='</div>';});
  return b||'<div class=empty style="padding:20px">no slices yet</div>';}
let TAB='runs',SUB='board';
async function refreshProject(id){let d;try{d=await(await api('/api/board?id='+id)).json();}catch(e){return;}
  const el=$('board');if(!d||d.error){el.innerHTML='<div class=empty style="padding:20px">board unreadable</div>';el.dataset.sig='';return;}
  const sig=id+'|'+SUB+'|'+(d.updated_at||'')+'|'+(d.slices||[]).map(s=>s.status+(s.tasks||[]).map(t=>t.status).join('')).join('|');
  if(el.dataset.sig===sig)return;el.dataset.sig=sig;
  const c=pcol(id),P=pctOf(d);
  const pipe=(d.slices||[]).map(s=>'<span class="seg s-'+s.status+'" title="'+esc(s.id)+': '+esc(s.title)+' ('+esc(s.status)+')"></span>').join('');
  el.innerHTML='<div class=phead><span class=tdot style="background:'+c+'"></span><span class=pname>'+esc(d.project||'board')+
    '</span><span class=ppct>'+P+'% done · updated '+esc(kago(d.updated_at))+'</span></div><div class=pipe>'+pipe+'</div>'+
    '<div class=subnav><button data-sub=board class="'+(SUB==='board'?'on':'')+'" style="border-color:'+(SUB==='board'?c:'transparent')+'">Board</button>'+
    '<button data-sub=roadmap class="'+(SUB==='roadmap'?'on':'')+'" style="border-color:'+(SUB==='roadmap'?c:'transparent')+'">Roadmap</button></div>'+
    '<div id=pview>'+(SUB==='roadmap'?roadmapHTML(d,c):kanbanHTML(d))+'</div>';}
function refresh(){TAB==='runs'?refreshRuns():refreshProject(TAB);}
async function loadTabs(){let boards=[];try{boards=await(await api('/api/boards')).json();}catch(e){}
  const t=$('tabs'),sig=['runs',...boards.map(b=>b.id)].join(',');
  if(t.dataset.sig===sig&&t.children.length)return;t.dataset.sig=sig;t.innerHTML='';
  const mk=(id,label)=>{const b=document.createElement('button');b.className='tab'+((''+TAB)===(''+id)?' on':'');
    b.innerHTML=(id==='runs'?'':'<span class=tdot style="background:'+pcol(id)+'"></span>')+esc(label);
    if(id!=='runs'&&(''+TAB)===(''+id))b.style.borderColor=pcol(id);
    b.onclick=()=>{TAB=id;SUB='board';$('board').dataset.sig='';[...t.children].forEach(x=>{x.classList.remove('on');x.style.borderColor='';});
      b.classList.add('on');if(id!=='runs')b.style.borderColor=pcol(id);
      $('runs').hidden=(id!=='runs');$('board').hidden=(id==='runs');refresh();};t.appendChild(b);};
  mk('runs','Runs');boards.forEach(b=>mk(b.id,b.name));}
$('board').addEventListener('click',e=>{const b=e.target.closest('[data-sub]');if(b){SUB=b.dataset.sub;$('board').dataset.sig='';refreshProject(TAB);}});
$('reap').addEventListener('change',e=>{const i=e.target;if(i.type==='checkbox'){i.checked?keptPids.delete(i.dataset.pids):keptPids.add(i.dataset.pids);}});
$('reapall').onclick=()=>{keptPids.clear();document.querySelectorAll('#reap input').forEach(c=>c.checked=true);};
$('reapnone').onclick=()=>document.querySelectorAll('#reap input').forEach(c=>{c.checked=false;keptPids.add(c.dataset.pids);});
loadTabs();refresh();setInterval(refresh,2000);setInterval(loadTabs,8000);
</script></body></html>"""


