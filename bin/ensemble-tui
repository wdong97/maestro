#!/usr/bin/env python3
"""maestro dashboard — interactive TUI over `ensemble jobs`.

Stdlib only (curses), so it runs anywhere python3 exists. Launched by
`ensemble dash`, which sets ENSEMBLE_BIN to the ensemble CLI path.

Keys:  j/k or arrows = move   a = attach/follow   x = kill   / = filter
       r = refresh now        enter = follow output   q = quit
Auto-refreshes every ~1.5s; the bottom pane live-previews the selected run's log.
"""
import curses, os, subprocess, time

ENSEMBLE = os.environ.get("ENSEMBLE_BIN", "ensemble")
REFRESH_MS = 1500
PANE = "res"    # bottom pane default: "res" (resource task-manager) or "log" (run output)
PS_SYS = {}     # latest system stats {rampct, used, total, swappct, load}
PS_AGENTS = []  # latest per-agent rows [{cpu, rss, mem, pid, kind, proj}]


def _num(x):
    try: return float(x)
    except (ValueError, TypeError): return 0.0


def get_ps_data():
    sysd, agents = {}, []
    try:
        out = subprocess.run([ENSEMBLE, "ps", "--porcelain"], capture_output=True,
                             text=True, timeout=8).stdout
    except Exception:
        return sysd, agents
    for line in out.splitlines():
        p = line.split("\t")
        if p[0] == "SYS" and len(p) >= 6:
            sysd = dict(rampct=_num(p[1]), used=p[2], total=p[3], swappct=_num(p[4]), load=p[5])
        elif p[0] == "A" and len(p) >= 7:
            agents.append(dict(cpu=_num(p[1]), rss=int(p[2] or 0), mem=_num(p[3]),
                               pid=p[4], kind=p[5], proj=p[6]))
    return sysd, agents


def bar(val, mx, width):
    mx = mx or 1
    f = int(round(min(val, mx) / mx * width))
    return "█" * f + "░" * (width - f)


def sev(pct, hi, mid):
    return curses.color_pair(3) if pct >= hi else curses.color_pair(2) if pct >= mid else curses.color_pair(1)


def hms(s):
    s = int(s)
    if s < 60: return f"{s}s"
    if s < 3600: return f"{s//60}m"
    return f"{s//3600}h{(s%3600)//60}m"


def get_jobs():
    try:
        out = subprocess.run([ENSEMBLE, "jobs", "--porcelain"],
                             capture_output=True, text=True, timeout=10).stdout
    except Exception:
        return []
    jobs = []
    for line in out.splitlines():
        p = line.split("\t")
        if len(p) >= 5:
            jobs.append(dict(kind=p[0], name=p[1], status=p[2], age=int(p[3] or 0), log=p[4]))
    jobs.sort(key=lambda j: j["age"])          # newest (smallest age) first
    return jobs


def tail(path, n):
    try:
        with open(path, "r", errors="replace") as f:
            return f.readlines()[-n:]
    except Exception:
        return ["(no output yet)"]


def tmux_target(job):
    if job["kind"] == "duel":  return f"duel-{job['name']}"
    if job["kind"] == "spawn": return "ensemble"
    return None


def run_fullscreen(cmd):
    """Drop out of curses, run an interactive command, come back."""
    curses.endwin()
    os.system(cmd)
    try: input("\n[enter to return to dashboard] ")
    except EOFError: pass


def _add(scr, y, x, s, attr=0):
    """Safe write: clamp to width-1 (never touch the last cell) and swallow ERR."""
    h, w = scr.getmaxyx()
    if y < 0 or y >= h or x < 0 or x >= w:
        return
    s = s[:max(0, w - x - 1)]
    try:
        scr.addstr(y, x, s, attr)
    except curses.error:
        pass


def draw(scr, jobs, sel, filt, msg):
    scr.erase()
    h, w = scr.getmaxyx()
    ncpu = sum(a["cpu"] for a in PS_AGENTS)
    rp = PS_SYS.get("rampct", 0)
    sub = f"  {len(jobs)} runs  ·  {len(PS_AGENTS)} agents  cpu {ncpu:.0f}%  ram {rp:.0f}%" + (f"  filter:'{filt}'" if filt else "")
    _add(scr, 0, 0, ("maestro dashboard" + sub).ljust(w), curses.A_BOLD | curses.A_REVERSE)

    list_h = max(3, (h - 6) // 2)
    _add(scr, 1, 0, f"  {'KIND':<8} {'NAME':<26} {'STATUS':<22} {'AGE':<5}".ljust(w), curses.A_UNDERLINE)
    top = max(0, sel - (list_h - 1))
    for i in range(top, min(len(jobs), top + list_h)):
        j = jobs[i]
        running = j["status"].startswith("running")
        row = f"  {j['kind']:<8} {j['name'][:26]:<26} {j['status'][:22]:<22} {hms(j['age']):<5}"
        attr = curses.A_REVERSE if i == sel else (curses.A_BOLD if running else curses.A_NORMAL)
        _add(scr, 2 + (i - top), 0, row.ljust(w), attr)

    py = 2 + list_h
    avail = h - py - 3
    if PANE == "res":
        _add(scr, py, 0, ("── agents — sorted by cpu (press p for run output) " + "─" * w), curses.A_DIM)
        r = py + 1
        s = PS_SYS
        if s:
            rpv = s["rampct"]
            sysline = (f"  RAM {rpv:>3.0f}% [{bar(rpv, 100, 14)}] {s['used']}/{s['total']}G"
                       f"   swap {s['swappct']:>3.0f}%   load {s['load']}")
            _add(scr, r, 0, sysline, sev(rpv, 85, 60) | curses.A_BOLD); r += 1
        _add(scr, r, 0, f"   {'CPU':>5}  {'':12}  {'RAM':>6} {'%MEM':>5} {'PID':<7} {'AGENT':<13} PROJECT",
             curses.A_DIM); r += 1
        maxcpu = max((a["cpu"] for a in PS_AGENTS), default=1) or 1
        for a in PS_AGENTS:
            if r >= h - 1:
                break
            att = sev(a["cpu"], maxcpu * 0.6, maxcpu * 0.25)
            row = (f"  {a['cpu']:>5.1f}% {bar(a['cpu'], maxcpu, 12)} {a['rss']:>5}M "
                   f"{a['mem']:>4.1f}% {a['pid']:<7} {a['kind']:<13} {a['proj']}")
            _add(scr, r, 0, row, att); r += 1
    else:
        _add(scr, py, 0, ("── output " + "─" * w), curses.A_DIM)
        if jobs:
            for k, ln in enumerate(tail(jobs[sel]["log"], avail)):
                _add(scr, py + 1 + k, 0, "  " + ln.rstrip("\n"))

    keys = "j/k move · a attach · x kill · p " + ("output" if PANE == "res" else "resources") + " · / filter · r refresh · q quit"
    foot = msg if msg else keys
    _add(scr, h - 1, 0, (" " + foot).ljust(w), curses.A_REVERSE)
    scr.refresh()


def prompt(scr, label):
    h, w = scr.getmaxyx()
    curses.echo(); curses.curs_set(1)
    _add(scr, h - 1, 0, (label + " ").ljust(w), curses.A_REVERSE)
    scr.refresh()
    try: s = scr.getstr(h - 1, len(label) + 1, 40).decode().strip()
    except Exception: s = ""
    curses.noecho(); curses.curs_set(0)
    return s


def main(scr):
    global PANE, PS_SYS, PS_AGENTS
    curses.curs_set(0); scr.timeout(REFRESH_MS)
    try:
        curses.start_color(); curses.use_default_colors()
        for i, fg in enumerate((curses.COLOR_GREEN, curses.COLOR_YELLOW,
                                curses.COLOR_RED, curses.COLOR_CYAN), 1):
            curses.init_pair(i, fg, -1)
    except curses.error:
        pass
    sel, filt, msg = 0, "", ""
    jobs = get_jobs(); PS_SYS, PS_AGENTS = get_ps_data()
    last = time.time()
    while True:
        shown = [j for j in jobs if filt.lower() in j["name"].lower()] if filt else jobs
        sel = max(0, min(sel, len(shown) - 1)) if shown else 0
        draw(scr, shown, sel, filt, msg)
        msg = ""
        c = scr.getch()
        if c == -1:
            if time.time() - last > REFRESH_MS / 1000:
                jobs = get_jobs(); PS_SYS, PS_AGENTS = get_ps_data()
                last = time.time()
            continue
        if c in (ord("q"),): break
        elif c in (curses.KEY_DOWN, ord("j")): sel += 1
        elif c in (curses.KEY_UP, ord("k")): sel -= 1
        elif c == ord("p"):
            PANE = "log" if PANE == "res" else "res"
        elif c in (ord("r"),):
            jobs = get_jobs(); PS_SYS, PS_AGENTS = get_ps_data()
            last = time.time()
        elif c == ord("/"): filt = prompt(scr, "filter:")
        elif c in (ord("a"), ord("\n"), curses.KEY_ENTER, 10, 13):
            if shown:
                j = shown[sel]; tgt = tmux_target(j)
                if tgt and subprocess.run(["tmux", "has-session", "-t", tgt],
                                          capture_output=True).returncode == 0:
                    run_fullscreen(f"tmux attach -t {tgt}")
                else:
                    run_fullscreen(f"{ENSEMBLE} tail {j['name']}")
                scr.timeout(REFRESH_MS); jobs = get_jobs()
        elif c == ord("x"):
            if shown:
                j = shown[sel]; tgt = tmux_target(j)
                if tgt and subprocess.run(["tmux", "kill-session", "-t", tgt],
                                          capture_output=True).returncode == 0:
                    msg = f"killed {tgt}"
                else:
                    msg = "no tmux session to kill for this run"
                jobs = get_jobs()


if __name__ == "__main__":
    import sys
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass
    except curses.error as e:
        print(f"[ensemble-tui] can't start interactive UI ({e}). "
              f"Run `ensemble dash` in a real terminal.", file=sys.stderr)
        sys.exit(1)
