#!/usr/bin/env python3
"""maestro dashboard — interactive TUI over `ensemble jobs`.

Stdlib only (curses), so it runs anywhere python3 exists. Launched by
`ensemble dash`, which sets ENSEMBLE_BIN to the ensemble CLI path.

Read-only watching, plus two guarded actions: `x` stops the selected run and `R`
reaps idle sessions — both ask first. Keystrokes never reach a live agent.
Runs are grouped into attention lanes: NEEDS YOU (just finished — recent and not
yet opened), RUNNING, DONE (older/handled, dim), and IDLE/RECLAIMABLE. A run
finishing rings the bell. NEEDS-YOU window: ENSEMBLE_DASH_RECENT_MIN (default 30).
Keys:  j/k or arrows = move   a/enter = follow (read-only)   x = stop   R = reap
       p = resources/output   / = filter   r = refresh   ? = help   q = quit
"""
import curses, os, re, shlex, subprocess, time

ENSEMBLE = os.environ.get("ENSEMBLE_BIN", "ensemble")
REFRESH_MS = 1500
PANE = "res"    # bottom pane default: "res" (resource task-manager) or "log" (run output)
PS_SYS = {}     # latest system stats {rampct, used, total, swappct, load}
PS_AGENTS = []  # latest per-agent rows [{cpu, rss, mem, pid, kind, proj}]


def _num(x):
    try: return float(x)
    except (ValueError, TypeError): return 0.0


def get_ps_data():
    """System stats + one row per open agent SESSION (process tree), RAM % of total."""
    sysd, stints = {}, []
    try:
        out = subprocess.run([ENSEMBLE, "ps", "--stints", "--porcelain"],
                             capture_output=True, text=True, timeout=8).stdout
    except Exception:
        return sysd, stints
    for line in out.splitlines():
        p = line.split("\t")
        if p[0] == "SYS" and len(p) >= 6:
            sysd = dict(rampct=_num(p[1]), used=p[2], total=p[3], swappct=_num(p[4]), load=p[5])
        elif p[0] == "T" and len(p) >= 7:
            stints.append(dict(pct=_num(p[1]), rss=int(p[2] or 0), cpu=_num(p[3]),
                               nprocs=p[4], kind=p[5], proj=p[6]))
    return sysd, stints


def bar(val, mx, width):
    mx = mx or 1
    f = int(round(min(val, mx) / mx * width))
    return "█" * f + "░" * (width - f)


def sev(pct, hi, mid):
    return curses.color_pair(3) if pct >= hi else curses.color_pair(2) if pct >= mid else curses.color_pair(1)


def hms(s):
    s = int(s)
    if s < 60: return f"{s}s"
    if s < 3600: return f"{s//60}m"
    return f"{s//3600}h{(s%3600)//60}m"


def get_jobs():
    try:
        out = subprocess.run([ENSEMBLE, "jobs", "--porcelain"],
                             capture_output=True, text=True, timeout=10).stdout
    except Exception:
        return []
    jobs = []
    for line in out.splitlines():
        p = line.split("\t")
        if len(p) >= 5:
            jobs.append(dict(kind=p[0], name=p[1], status=p[2], age=int(p[3] or 0), log=p[4]))
    jobs.sort(key=lambda j: j["age"])          # newest (smallest age) first
    return jobs


def tail(path, n):
    try:
        # newline="\n": don't split on lone "\r" so clean_line can collapse
        # carriage-return progress redraws into their final frame.
        with open(path, "r", errors="replace", newline="\n") as f:
            return f.readlines()[-n:]
    except Exception:
        return ["(no output yet)"]


# Agent logs are raw terminal streams: ANSI colour codes, OSC titles, and `\r`
# progress redraws that curses can't interpret and would dump as garbage.
_ANSI = re.compile(r"\x1b\[[0-9;?]*[ -/]*[@-~]|\x1b\][^\x07\x1b]*(?:\x07|\x1b\\)|\x1b[@-_]")
_CTRL = re.compile(r"[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]")


def clean_line(s):
    s = s.rstrip("\n").rstrip("\r")
    if "\r" in s:                       # in-place progress redraw: keep the last frame
        s = s.split("\r")[-1]
    s = _ANSI.sub("", s)
    s = s.replace("\t", "    ")
    s = _CTRL.sub("", s)
    return s.rstrip()


def prep_output(path, n):
    """Last n display-ready lines: stripped of terminal codes, blank runs collapsed."""
    out = []
    for x in tail(path, n * 3 + 10):
        ln = clean_line(x)
        if ln == "" and (not out or out[-1] == ""):
            continue                    # collapse consecutive blanks
        out.append(ln)
    while out and out[0] == "":         # trim leading blank
        out.pop(0)
    return out[-n:] if n > 0 else []


def run_fullscreen(cmd):
    """Drop out of curses, run an interactive command, come back."""
    curses.endwin()
    os.system(cmd)
    try: input("\n[enter to return to dashboard] ")
    except EOFError: pass


def _add(scr, y, x, s, attr=0):
    """Safe write: clamp to width-1 (never touch the last cell) and swallow ERR."""
    h, w = scr.getmaxyx()
    if y < 0 or y >= h or x < 0 or x >= w:
        return
    s = s[:max(0, w - x - 1)]
    try:
        scr.addstr(y, x, s, attr)
    except curses.error:
        pass


# --- run classification: lane + badge + action hint ------------------------
def job_state(j):
    s = j["status"]
    if s.startswith("running"): return "running"
    if "stopped" in s.lower():  return "stopped"
    codes = re.findall(r"-?\d+", s)
    if codes and any(int(c) != 0 for c in codes): return "failed"
    return "done"


_BADGE = {"running": ("●", 4), "done": ("✓", 1), "failed": ("✗", 3), "stopped": ("■", 2)}


def job_action(j, st):
    if st == "done" and j["kind"] == "duel":   return "synthesize"
    if st == "done" and j["kind"] == "review": return "read review"
    return {"running": "live", "done": "done", "failed": "failed", "stopped": "stopped"}[st]


def _envmin(name, default):
    try: return max(1, int(os.environ.get(name, default))) * 60
    except (ValueError, TypeError): return int(default) * 60

NEEDS_SECS = _envmin("ENSEMBLE_DASH_RECENT_MIN", "30")  # a finished run "needs you" this long
FAIL_SECS = NEEDS_SECS * 8                              # failures/stops linger longer
DONE_CAP = 10                                          # max older runs shown before "+N more"


def lane_of(j, acked):
    """needs = finished, recent, and not yet acknowledged; done = older or acked."""
    st = job_state(j)
    if st == "running":     return "running"
    if j["name"] in acked:  return "done"
    window = FAIL_SECS if st in ("failed", "stopped") else NEEDS_SECS
    return "needs" if j["age"] < window else "done"


def reload(prev):
    """Refresh jobs + ps; return a one-line note for any run that just finished
    (and mutate prev to the new statuses so the next call can diff again)."""
    jobs = get_jobs(); sysd, agents = get_ps_data()
    fin = [j for j in jobs if prev.get(j["name"], "").startswith("running")
           and not j["status"].startswith("running")]
    note = ""
    if fin:
        sym = "✗" if any(job_state(j) in ("failed", "stopped") for j in fin) else "✓"
        extra = f" +{len(fin) - 1} more" if len(fin) > 1 else ""
        note = f"{sym} {fin[0]['name']}{extra} finished"
    prev.clear(); prev.update({j["name"]: j["status"] for j in jobs})
    return jobs, sysd, agents, note


def draw_help(scr):
    """Modal help overlay; blocks until any key, then returns."""
    h, w = scr.getmaxyx()
    lines = [
        "maestro dashboard — help", "",
        "LANES",
        "  NEEDS YOU   runs that just finished (recent + not yet opened)",
        "  RUNNING     live agents — read-only, keystrokes never reach them",
        "  DONE        older / already-opened runs (dim; a still follows them)",
        "  IDLE        open sessions you can reclaim with reap", "",
        "KEYS",
        "  j / k / arrows   move selection",
        "  a / enter        follow output (read-only)",
        "  x                stop the selected run (asks first)",
        "  R                reap idle sessions + dev servers",
        "  p                toggle resources / output pane",
        "  / filter    r refresh    q quit", "",
        "press any key to close",
    ]
    bw = min(w - 2, max(len(l) for l in lines) + 4); bh = len(lines) + 2
    y0, x0 = max(0, (h - bh) // 2), max(0, (w - bw) // 2)
    for i in range(bh):
        _add(scr, y0 + i, x0, " " * bw, curses.A_REVERSE)
    for i, l in enumerate(lines):
        a = curses.A_REVERSE | (curses.A_BOLD if l in ("LANES", "KEYS") or l.endswith("help") else 0)
        _add(scr, y0 + 1 + i, x0 + 2, l, a)
    scr.refresh()
    scr.timeout(-1); scr.getch(); scr.timeout(REFRESH_MS)


def draw(scr, needs, running, done, idle_n, sel, filt, msg):
    scr.erase()
    h, w = scr.getmaxyx()
    disp_done = done[:DONE_CAP]
    selectable = needs + running + disp_done
    ncpu = sum(a["cpu"] for a in PS_AGENTS); rp = PS_SYS.get("rampct", 0)
    sub = (f"  {len(needs) + len(running)} active · {len(PS_AGENTS)} sessions · cpu {ncpu:.0f}% · ram {rp:.0f}%"
           + (f"   /{filt}" if filt else ""))
    _add(scr, 0, 0, ("  maestro" + sub).ljust(w), curses.A_BOLD | curses.A_REVERSE)

    # top section: attention lanes (NEEDS YOU / RUNNING / DONE / IDLE summary)
    list_h = max(6, (h - 6) // 2)
    rows = [("lane", f"NEEDS YOU ({len(needs)})")]
    rows += [("job", j) for j in needs] or [("empty", "nothing fresh — you're caught up")]
    rows.append(("lane", f"RUNNING ({len(running)})"))
    rows += [("job", j) for j in running] or [("empty", "nothing running")]
    if done:
        rows.append(("lane", f"DONE ({len(done)})"))
        rows += [("donejob", j) for j in disp_done]
        if len(done) > DONE_CAP:
            rows.append(("more", f"+{len(done) - DONE_CAP} older · / to filter"))
    rows.append(("idle", f"IDLE / RECLAIMABLE ({idle_n})    → R to reap"))

    job_at = [i for i, (t, _) in enumerate(rows) if t in ("job", "donejob")]
    sel_row = job_at[sel] if (job_at and 0 <= sel < len(job_at)) else 0
    start = max(0, min(sel_row - list_h // 2, len(rows) - list_h)) if len(rows) > list_h else 0
    y = 1
    for i in range(start, min(len(rows), start + list_h)):
        t, payload = rows[i]
        if t == "lane":
            _add(scr, y, 0, (" " + payload).ljust(w), curses.A_BOLD | curses.A_UNDERLINE)
        elif t in ("empty", "idle", "more"):
            _add(scr, y, 0, ("   " if t != "idle" else " ") + payload, curses.A_DIM)
        else:
            j = payload; st = job_state(j); bch, bcol = _BADGE[st]; dim = (t == "donejob")
            text = (f"  {bch} {j['kind'][:8]:<8} {j['name'][:25]:<25} "
                    f"{job_action(j, st)[:12]:<12} {hms(j['age']):>4}")
            if job_at and sel < len(job_at) and i == job_at[sel]:
                _add(scr, y, 0, text.ljust(w), curses.A_REVERSE)
            else:
                base = curses.A_DIM if dim else (curses.A_BOLD if st == "running" else curses.A_NORMAL)
                _add(scr, y, 0, text.ljust(w), base)
                _add(scr, y, 2, bch, curses.color_pair(bcol) | (curses.A_DIM if dim else curses.A_BOLD))
        y += 1

    py = 1 + list_h
    avail = h - py - 3
    if PANE == "res":
        _add(scr, py, 0, ("── open sessions — RAM % of total, tree summed (p for run output) " + "─" * w), curses.A_DIM)
        r = py + 1
        s = PS_SYS
        if s:
            rpv = s["rampct"]
            sysline = (f"  RAM {rpv:>3.0f}% [{bar(rpv, 100, 14)}] {s['used']}/{s['total']}G"
                       f"   swap {s['swappct']:>3.0f}%   load {s['load']}")
            _add(scr, r, 0, sysline, sev(rpv, 85, 60) | curses.A_BOLD); r += 1
        _add(scr, r, 0, f"   {'RAM%':>5}  {'':12}  {'RAM':>6} {'CPU':>5} {'PROCS':>6} {'AGENT':<7} PROJECT",
             curses.A_DIM); r += 1
        maxpct = max((a["pct"] for a in PS_AGENTS), default=1) or 1
        for a in PS_AGENTS:
            if r >= h - 1:
                break
            att = sev(a["pct"], maxpct * 0.6, maxpct * 0.25)
            row = (f"  {a['pct']:>5.1f}% {bar(a['pct'], maxpct, 12)} {a['rss']:>5}M "
                   f"{a['cpu']:>4.0f}% {a['nprocs']:>5}p {a['kind']:<7} {a['proj']}")
            _add(scr, r, 0, row, att); r += 1
    else:
        j = selectable[sel] if (selectable and sel < len(selectable)) else None
        if j:
            run = j["status"].startswith("running")
            hdr = f"── output · {j['kind']}/{j['name']} · {'live' if run else 'done'} "
            hattr = (curses.color_pair(4) | curses.A_BOLD) if run else curses.A_DIM
        else:
            hdr, hattr = "── output ", curses.A_DIM
        _add(scr, py, 0, hdr + "─" * w, hattr)
        if j:
            lines = prep_output(j["log"], avail)
            last = max((i for i, ln in enumerate(lines) if ln), default=-1)
            for k, ln in enumerate(lines):
                att = curses.A_BOLD if (run and k == last) else curses.A_NORMAL
                _add(scr, py + 1 + k, 0, "  " + ln, att)
            if not lines:
                _add(scr, py + 1, 0, "  (no output yet)", curses.A_DIM)

    keys = "j/k move · a follow · x stop · R reap · p panes · / filter · ? help · q quit"
    _add(scr, h - 1, 0, (" " + (msg or keys)).ljust(w), curses.A_REVERSE)
    scr.refresh()


def prompt(scr, label):
    h, w = scr.getmaxyx()
    curses.echo(); curses.curs_set(1)
    _add(scr, h - 1, 0, (label + " ").ljust(w), curses.A_REVERSE)
    scr.refresh()
    try: s = scr.getstr(h - 1, len(label) + 1, 40).decode().strip()
    except Exception: s = ""
    curses.noecho(); curses.curs_set(0)
    return s


def main(scr):
    global PANE, PS_SYS, PS_AGENTS
    curses.curs_set(0); scr.timeout(REFRESH_MS)
    try:
        curses.start_color(); curses.use_default_colors()
        for i, fg in enumerate((curses.COLOR_GREEN, curses.COLOR_YELLOW,
                                curses.COLOR_RED, curses.COLOR_CYAN), 1):
            curses.init_pair(i, fg, -1)
    except curses.error:
        pass
    sel, filt, msg = 0, "", ""
    prev, acked = {}, set()
    jobs, PS_SYS, PS_AGENTS, _ = reload(prev)   # seeds prev; first load never beeps
    last = time.time()
    while True:
        shown = [j for j in jobs if filt.lower() in j["name"].lower()] if filt else jobs
        running = [j for j in shown if job_state(j) == "running"]
        needs = [j for j in shown if lane_of(j, acked) == "needs"]
        done = [j for j in shown if lane_of(j, acked) == "done"]
        selectable = needs + running + done[:DONE_CAP]
        sel = max(0, min(sel, len(selectable) - 1)) if selectable else 0
        idle_n = sum(1 for a in PS_AGENTS if a["cpu"] < 1.0)
        draw(scr, needs, running, done, idle_n, sel, filt, msg)
        msg = ""
        c = scr.getch()
        if c == -1:
            if time.time() - last > REFRESH_MS / 1000:
                jobs, PS_SYS, PS_AGENTS, note = reload(prev)
                if note: curses.beep(); msg = note
                last = time.time()
            continue
        if c == ord("q"): break
        elif c in (curses.KEY_DOWN, ord("j")): sel += 1
        elif c in (curses.KEY_UP, ord("k")): sel -= 1
        elif c == ord("p"): PANE = "log" if PANE == "res" else "res"
        elif c == ord("?"): draw_help(scr)
        elif c == ord("r"):
            jobs, PS_SYS, PS_AGENTS, note = reload(prev)
            if note: curses.beep(); msg = note
            last = time.time()
        elif c == ord("/"): filt = prompt(scr, "filter:")
        elif c == ord("R"):
            # reap is interactive (its own keep/confirm); drop out of curses for it.
            run_fullscreen(f"{shlex.quote(ENSEMBLE)} reap")
            scr.timeout(REFRESH_MS); jobs, PS_SYS, PS_AGENTS, _ = reload(prev); last = time.time()
        elif c in (ord("a"), ord("\n"), curses.KEY_ENTER, 10, 13):
            if selectable:
                # read-only: follow the run's log (tail -f). Never attach to the live
                # tmux session, so keystrokes can't reach — or disrupt — the agent.
                # shlex.quote the name: it comes from `jobs` (a --name can hold shell
                # metachars), and run_fullscreen runs it through os.system.
                acked.add(selectable[sel]["name"])   # you've looked — drop it from NEEDS YOU
                run_fullscreen(f"{shlex.quote(ENSEMBLE)} tail {shlex.quote(selectable[sel]['name'])}")
                scr.timeout(REFRESH_MS); jobs, PS_SYS, PS_AGENTS, _ = reload(prev); last = time.time()
        elif c == ord("x"):
            # the one in-pane write action: stop the selected run, behind a y/N confirm.
            if selectable:
                j = selectable[sel]
                if prompt(scr, f"stop {j['kind']} '{j['name']}'? [y/N]")[:1].lower() == "y":
                    subprocess.run([ENSEMBLE, "stop", "--yes", j["name"]], capture_output=True)
                    acked.add(j["name"]); msg = f"stopped {j['name']}"
                    jobs, PS_SYS, PS_AGENTS, _ = reload(prev)
                else:
                    msg = "stop cancelled"


if __name__ == "__main__":
    import sys
    try:
        curses.wrapper(main)
    except KeyboardInterrupt:
        pass
    except curses.error as e:
        print(f"[ensemble-tui] can't start interactive UI ({e}). "
              f"Run `ensemble dash` in a real terminal.", file=sys.stderr)
        sys.exit(1)
